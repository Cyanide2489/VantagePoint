{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview",
      "startServerReadyPattern": "Listening on",
      "url": [
        "http://127.0.0.1:3000/",
        "http://127.0.0.1:3000/onboarding"
      ],
      "settings": {
        "chromeFlags": "--no-sandbox --headless --disable-gpu --disable-dev-shm-usage"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
